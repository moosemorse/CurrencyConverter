@using CurrencyConverter.Web.Core.Interfaces

@rendermode InteractiveServer
@inject NavigationManager Nav
@inject ICurrencyConverterService CurrencyConverterService
@inject IPrettyPrintService PrettyPrintService

<!-- Note: If using SSR, use stream rendering, =>
     helps interactivity by loading what's available while waiting for backend
-->

@if (userInput is null)
{
    <div class="d-flex justify-content-center mt-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
    return;
}
else
{
    <EditForm Model="@userInput" FormName="enterInput" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    
    <div class="calc-container">
        <div class="calc-card">
            <div class="calc-card-body">
                
                <div class="row g-4">
                    <div class="col-12">
                        <label class="calc-label" for="amount">Amount</label>
                        <InputNumber id="amount" class="form-control calc-input" @bind-Value="userInput.Amount" placeholder="0.00" />
                    </div>

                    <div class="col-6">
                        <label class="calc-label" for="starting-rate">From (@GetDisplayName(userInput.StartingRate))</label>
                        <InputSelect id="starting-rate" class="form-select calc-input" @bind-Value="userInput.StartingRate">
                            @foreach (var rate in allRates)
                            {
                                <option value="@rate">@rate</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-6">
                        <label class="calc-label" for="target-rate">To (@GetDisplayName(userInput.TargetRate))</label>
                        <InputSelect id="target-rate" class="form-select calc-input" @bind-Value="userInput.TargetRate">
                            @foreach (var rate in allRates)
                            {
                                <option value="@rate">@rate</option>
                            }
                        </InputSelect>
                    </div>
                    
                    <div class="col-12">
                        <button type="submit" 
                                class="btn btn-primary calc-btn"
                                disabled="@(userInput.Amount is null || userInput.Amount < 0)">
                            Convert Currency
                        </button>
                    </div>
                    
                    @if (conversionResult.HasValue)
                    {
                        <div class="col-12">
                            <div class="calc-result-banner">
                                <span class="calc-result-label">Converted Amount</span>
                                <h2 class="calc-result-value">
                                    @conversionResult.Value.ToString("N2") @userInput.TargetRate
                                </h2>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-3">
                    <ValidationSummary class="text-danger" />
                </div>
            </div>
        </div>
    </div>
    </EditForm>

}

@code {

    // REMEMBER: dotnet watch might just not pick up changes so restart first
    [SupplyParameterFromQuery(Name = "from")]
    public string? from { get; set; }

    [SupplyParameterFromQuery(Name = "to")]
    public string? to { get; set; }

    [SupplyParameterFromQuery(Name = "amount")]
    public double? amount { get; set; }

    // TODO: can these all be abstracted somewhere? like a data validator class
    private ExchangeRate[] allRates = Enum.GetValues<ExchangeRate>();
    private ExchangeRate defaultRate = ExchangeRate.GBP;
    private double defualtAmount = 1;
    
    // we have to tell blazor the object that contains all the data entered by the user
    // it knows userInput is the model but not how the data arrives into the server so we have to use extra attribute
    // this is populated by blazor when the form is submitted, so we can use it in the submit handler
    [SupplyParameterFromForm]

    // https://learn.microsoft.com/en-us/aspnet/core/diagnostics/bl0008?view=aspnetcore-10.0
    // OnInitialized{Async} lifecycle methods used to avoid warnings
    public ConverterInput? userInput { get; set; }

    private double? conversionResult;

    private Dictionary<string, string> currencyNames = new();


    // TODO
    // still some bugs I found that need to be fixed:
    // 1. if you enter invalid data into form, rates are handled by convertExchangeRate but URI is not updated and left stale
    // ok ok so I started doing 1. and just like the past 1-2 hours its just tireless validation so Ill come back to this later and actually 
    //    get something more useful done
    //    OKKK so I realised that if you do to=rubbish, then rubbish is not null so that means this is not a sufficient condition to check for validity
    //    ok, i will leave this for TODO: we have a validation routine to check if entry maps to something in our enum
    // 2. Amounts if you enter something like '125.50.50' then blazor parsing fails and you get error message that it cannot parse
    // 3. Extra validation perhap?? really extra is to make sure amount can only have two dp
    // 4. Another bug --> Cannot parse the value '1E-45' as type 'System.Nullable`1[System.Double]' for 'amount'.
    protected override void OnParametersSet()
    {

        // shuold probably be called like validated{field}
        var fromURI = convertExchangeRate(from);
        var toURI = convertExchangeRate(to);
        var amountURI = (amount is not null && amount >= 0) ? amount : defualtAmount;

        if (from is null || to is null || amount is null)
        {
            Nav.NavigateTo($"/?from={fromURI.ToString()}&to={toURI.ToString()}&amount={amountURI}", forceLoad: true);
        }

        // we get to this point if all query params are non null 
        userInput = new ConverterInput() {
            StartingRate = fromURI,
            TargetRate = toURI,
            Amount = amountURI
        };
        
    }

    protected override async Task OnInitializedAsync() {
        currencyNames = await PrettyPrintService.GetAllCurrencyNamesAsync();
    }

    private string getURI() {
        ArgumentNullException.ThrowIfNull(userInput);
        return $"/?from={userInput.StartingRate}&to={userInput.TargetRate}&amount={userInput.Amount}";
    }

    private ExchangeRate convertExchangeRate(string? rate) => Enum.TryParse<ExchangeRate>(rate, true, out var result) ? result : defaultRate;

    private async Task HandleSubmit() {

        ArgumentNullException.ThrowIfNull(userInput, nameof(userInput));

        conversionResult = await CurrencyConverterService.getConversionAsync(userInput);

        // note: for the history this took for ever and i think fix was just to add interactiveserver ??
        Nav.NavigateTo(getURI());
    }

    private string GetDisplayName(ExchangeRate rate) 
    {
        var key = rate.ToString().ToLower();
        return currencyNames.TryGetValue(key, out var name) ? name : rate.ToString();
    }
}
